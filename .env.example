# ============================================
# Krastix Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- AI / LLM ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Web Scraping ---
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
SCRAPECREATORS_API_KEY=your-scrapecreators-api-key-here

# --- Database (Supabase) ---
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-region.pooler.supabase.com:6543/postgres

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# --- Redis (handled by Docker Compose, override if needed) ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# --- Google OAuth (Communication Agent / Gmail) ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/oauth/callback

# --- Integration Secret Encryption ---
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATIONS_ENCRYPTION_KEY=your-fernet-key
